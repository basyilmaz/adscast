APP_NAME=AdsCast
APP_ENV=production
APP_KEY=base64:CHANGE_ME_GENERATED_APP_KEY
APP_URL=https://adscast.castintech.com
APP_TIMEZONE=Europe/Istanbul
FRONTEND_ORIGIN=https://adscast.castintech.com

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CHANGE_ME_ADSCAST_DB
DB_USERNAME=CHANGE_ME_ADSCAST_DB_USER
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_PREFIX=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://adscast.castintech.com/settings/meta/callback
META_API_VERSION=v20.0
META_WEBHOOK_VERIFY_TOKEN=

AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_TEMPERATURE=0.2

NEXT_PUBLIC_APP_NAME=AdsCast
NEXT_PUBLIC_API_BASE_URL=https://adscast.castintech.com/api/v1
